generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum StatusCategory {
  BACKLOG
  UNSTARTED
  STARTED
  BLOCKED
  COMPLETED
  CANCELED
}

enum IssuePriority {
  NO_PRIORITY
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  initials     String
  title        String?
  avatarUrl    String?
  createdAt    DateTime @default(now())

  memberships        WorkspaceMember[]
  projectMemberships ProjectMember[]
  assignedIssues     Issue[]              @relation("IssueAssignee")
  createdIssues      Issue[]              @relation("IssueCreator")
  ledProjects        Project[]            @relation("ProjectLead")
  ownedGoals         Goal[]               @relation("GoalOwner")
  comments           Comment[]
  commentReactions   CommentReaction[]
  activity           ActivityLog[]
  chatMessages       ProjectChatMessage[]
  chatReactions      ProjectChatReaction[]
  drafts             Draft[]
  favorites          Favorite[]
  notificationsReceived Notification[]    @relation("NotificationRecipient")
  notificationsSent  Notification[]       @relation("NotificationActor")
  refreshTokens      RefreshToken[]
  sentInvites        WorkspaceInvite[]    @relation("InviteSender")
}

model RefreshToken {
  id                  String    @id @default(cuid())
  tokenHash           String    @unique
  user                User      @relation(fields: [userId], references: [id])
  userId              String
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedByTokenHash String?
  createdAt           DateTime  @default(now())

  @@index([userId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  color     String   @default("#6e79d6")
  createdAt DateTime @default(now())

  members  WorkspaceMember[]
  projects Project[]
  labels   Label[]
  invites  WorkspaceInvite[]
}

model WorkspaceInvite {
  id          String       @id @default(cuid())
  email       String
  role        Role         @default(MEMBER)
  tokenHash   String       @unique
  status      InviteStatus @default(PENDING)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  invitedBy   User         @relation("InviteSender", fields: [invitedById], references: [id])
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([workspaceId])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  role        Role      @default(MEMBER)
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  createdAt   DateTime  @default(now())

  @@unique([userId, workspaceId])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  teamKey     String
  color       String        @default("#6e79d6")
  summary     String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  targetDate  DateTime?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  lead        User?         @relation("ProjectLead", fields: [leadId], references: [id])
  leadId      String?
  createdAt   DateTime      @default(now())

  members       ProjectMember[]
  issues        Issue[]
  cycles        Cycle[]
  goals         Goal[]
  milestones    Milestone[]
  drafts        Draft[]
  chatMessages  ProjectChatMessage[]
  statusOptions IssueStatusOption[]

  @@unique([workspaceId, teamKey])
}

model IssueStatusOption {
  id        String         @id @default(cuid())
  name      String
  color     String
  icon      String         @default("Circle")
  category  StatusCategory
  position  Int            @default(0)
  isDefault Boolean        @default(false)
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  issues    Issue[]
  createdAt DateTime       @default(now())

  @@unique([projectId, name])
}

model ProjectMember {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Cycle {
  id          String   @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  issues      Issue[]
  createdAt   DateTime @default(now())
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String?
  targetDate  DateTime
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  owner       User?    @relation("GoalOwner", fields: [ownerId], references: [id])
  ownerId     String?
  createdAt   DateTime @default(now())
}

model Milestone {
  id          String   @id @default(cuid())
  title       String
  description String?
  targetDate  DateTime
  completed   Boolean  @default(false)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime @default(now())
}

model Label {
  id          String       @id @default(cuid())
  name        String
  color       String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  issues      IssueLabel[]

  @@unique([workspaceId, name])
}

model Issue {
  id                   String        @id @default(cuid())
  identifier           Int
  title                String
  description          String?
  status               IssueStatusOption @relation(fields: [statusId], references: [id])
  statusId             String
  priority             IssuePriority @default(NO_PRIORITY)
  position             Int           @default(0)
  project              Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            String
  cycle                Cycle?        @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  cycleId              String?
  assignee             User?         @relation("IssueAssignee", fields: [assigneeId], references: [id])
  assigneeId           String?
  creator              User          @relation("IssueCreator", fields: [creatorId], references: [id])
  creatorId            String
  parent               Issue?        @relation("SubIssues", fields: [parentId], references: [id], onDelete: SetNull)
  parentId             String?
  subIssues            Issue[]       @relation("SubIssues")
  blockedBy            Issue?        @relation("IssueBlocks", fields: [blockedById], references: [id], onDelete: SetNull)
  blockedById          String?
  blocking             Issue[]       @relation("IssueBlocks")
  labels               IssueLabel[]
  comments             Comment[]
  activity             ActivityLog[]
  attachments          Attachment[]
  favoritedBy          Favorite[]
  aiSuggestedLabels    String[]      @default([])
  aiSuggestedReasoning String?
  archived             Boolean       @default(false)
  dueDate              DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([projectId, identifier])
}

model Attachment {
  id      String @id @default(cuid())
  name    String
  size    String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String
}

model IssueLabel {
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)
  labelId String

  @@id([issueId, labelId])
}

model Comment {
  id               String    @id @default(cuid())
  body             String
  issue            Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId          String
  author           User      @relation(fields: [authorId], references: [id])
  authorId         String
  parent           Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId         String?
  replies          Comment[] @relation("CommentReplies")
  mentionedUserIds String[]  @default([])
  editedAt         DateTime?
  createdAt        DateTime  @default(now())

  attachments CommentAttachment[]
  reactions   CommentReaction[]

  @@index([issueId])
}

model CommentAttachment {
  id        String  @id @default(cuid())
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  name      String
  url       String
  size      String
  isImage   Boolean @default(false)
}

model CommentReaction {
  id        String  @id @default(cuid())
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  user      User    @relation(fields: [userId], references: [id])
  userId    String
  emoji     String

  @@unique([commentId, userId, emoji])
}

model ActivityLog {
  id        String   @id @default(cuid())
  message   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId   String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
}

model ProjectChatMessage {
  id               String              @id @default(cuid())
  body             String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  author           User                @relation(fields: [authorId], references: [id])
  authorId         String
  parent           ProjectChatMessage? @relation("ProjectChatReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId         String?
  replies          ProjectChatMessage[] @relation("ProjectChatReplies")
  mentionedUserIds String[]            @default([])
  editedAt         DateTime?
  createdAt        DateTime            @default(now())

  attachments ProjectChatAttachment[]
  reactions   ProjectChatReaction[]

  @@index([projectId])
}

model ProjectChatAttachment {
  id        String             @id @default(cuid())
  message   ProjectChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  name      String
  url       String
  size      String
  isImage   Boolean            @default(false)
}

model ProjectChatReaction {
  id        String             @id @default(cuid())
  message   ProjectChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User               @relation(fields: [userId], references: [id])
  userId    String
  emoji     String

  @@unique([messageId, userId, emoji])
}

model Draft {
  id          String        @id @default(cuid())
  title       String
  description String?
  priority    IssuePriority @default(NO_PRIORITY)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  author      User          @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId   String
  createdAt DateTime @default(now())

  @@unique([userId, issueId])
}

model Notification {
  id              String    @id @default(cuid())
  recipient       User      @relation("NotificationRecipient", fields: [recipientId], references: [id])
  recipientId     String
  actor           User      @relation("NotificationActor", fields: [actorId], references: [id])
  actorId         String
  message         String
  issueIdentifier String?
  readAt          DateTime?
  createdAt       DateTime  @default(now())
}
