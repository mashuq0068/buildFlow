PORT=4000
CLIENT_ORIGIN=http://localhost:3000

DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_NAME=pm_db
DB_PORT=5432
DB_SSL=false

DATABASE_URL="postgresql://postgres:your_password@localhost:5432/pm_db?schema=public"

JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=false

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Your App <your_email@gmail.com>"
SMTP_REPLY_TO=your_email@gmail.com

INVITE_TOKEN_TTL_DAYS=7
